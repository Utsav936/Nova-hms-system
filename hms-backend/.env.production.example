# 🏥 Nova HMS Backend Production Environment Variables
# Use these keys in Google Cloud Secret Manager

# Server Configuration
PORT=8080
NODE_ENV=production

# URLs
CLIENT_URL=https://your-frontend-domain.com

# Firebase Admin SDK (Cloud Run Service Account usually handles this, 
# but if you use the JSON, store it here as a single-line JSON string)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Security
JWT_ACCESS_SECRET=your_long_random_string_here
JWT_REFRESH_SECRET=your_another_long_random_string_here
